---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";

const productos = await getCollection("products");
---

<BaseLayout title="Catálogo">
  <main style="max-width: 1100px; margin: 0 auto; padding: 2rem 1rem;">
    <h1>Catálogo — Amarillo Primavera</h1>
    <p>{productos.length} productos migrados.</p>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem;">
      {
        productos.map((producto) => (
          <a
            href={`/productos/${producto.id}/`}
            style="text-decoration: none; color: inherit;"
          >
            {producto.data.imagenes[0] && (
              <Image
                src={producto.data.imagenes[0]}
                alt={producto.data.nombre}
                width={220}
                height={220}
                style="width: 100%; height: 220px; object-fit: cover; border-radius: 8px;"
              />
            )}
            <h3>{producto.data.nombre}</h3>
            <p style="font-size: 0.85rem; opacity: 0.8;">
              {producto.data.categoria} · {producto.data.disponible ? "Disponible" : "Sobre pedido"}
            </p>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>
