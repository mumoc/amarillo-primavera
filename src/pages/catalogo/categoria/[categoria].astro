---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductCard from "../../../components/ProductCard.astro";
import CategorySidebar from "../../../components/CategorySidebar.astro";
import { slugify } from "../../../lib/slug";

export async function getStaticPaths() {
  const productos = await getCollection("products");
  const categorias = [...new Set(productos.map((p) => p.data.categoria))];

  return categorias.map((categoria) => ({
    params: { categoria: slugify(categoria) },
    props: {
      categoria,
      categorias,
      productos: productos.filter((p) => p.data.categoria === categoria),
    },
  }));
}

const { categoria, categorias, productos } = Astro.props;
const categoriasOrdenadas = [...categorias].sort((a, b) => a.localeCompare(b, "es"));
---

<BaseLayout title={categoria} description={`Productos de la categoría ${categoria} en Amarillo Primavera.`}>
  <main class="container catalogo">
    <h1>Catálogo</h1>

    <div class="catalogo__layout">
      <aside class="catalogo__sidebar">
        <CategorySidebar categorias={categoriasOrdenadas} activa={categoria} />
      </aside>

      <div class="catalogo__contenido">
        <h2>{categoria}</h2>
        <p class="catalogo__conteo">{productos.length} productos</p>
        <div class="catalogo__grid">
          {productos.map((producto, i) => <ProductCard producto={producto} prioridad={i < 4} />)}
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .catalogo {
    padding: 2.5rem 0 3rem;
  }

  .catalogo__layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 760px) {
    .catalogo__layout {
      grid-template-columns: 1fr;
    }
  }

  .catalogo__sidebar {
    position: sticky;
    top: 5.5rem;
  }

  @media (max-width: 760px) {
    .catalogo__sidebar {
      position: static;
    }
  }

  .catalogo__conteo {
    color: var(--color-gris-morado);
    margin-bottom: 1.5rem;
  }

  .catalogo__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 1.5rem;
  }
</style>
