---
import { getCollection, render } from "astro:content";
import { Image, getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { whatsappOrderLink, SITE_NAME } from "../../config/site";

export async function getStaticPaths() {
  const productos = await getCollection("products");
  return productos.map((producto) => ({
    params: { id: producto.id },
    props: { producto },
  }));
}

const { producto } = Astro.props;
const { nombre, categoria, tags, disponible, imagenes } = producto.data;
const { Content } = await render(producto);

const descripcionCorta = `${nombre} — ${categoria}, una creación artesanal de Amarillo Primavera.`;

const imagenOptimizada = imagenes[0]
  ? await getImage({ src: imagenes[0], width: 640, height: 640 })
  : null;

const productoJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: nombre,
  category: categoria,
  description: producto.body?.trim().slice(0, 500) || descripcionCorta,
  image: imagenOptimizada ? [new URL(imagenOptimizada.src, Astro.site).toString()] : undefined,
  brand: { "@type": "Brand", name: SITE_NAME },
  ...(disponible
    ? { offers: { "@type": "Offer", availability: "https://schema.org/InStock", url: Astro.url.toString() } }
    : {}),
};
---

<BaseLayout title={nombre} description={descripcionCorta} image={imagenOptimizada?.src}>
  <script type="application/ld+json" set:html={JSON.stringify(productoJsonLd)} />
  <main class="container producto">
    <div class="producto__galeria" data-galeria>
      <div class="producto__imagen-principal">
        {
          imagenes.map((imagen, i) => (
            <Image
              src={imagen}
              alt={`${nombre} — foto ${i + 1}`}
              width={640}
              height={640}
              loading={i === 0 ? "eager" : "lazy"}
              data-galeria-principal
              data-index={i}
              hidden={i !== 0}
            />
          ))
        }
      </div>

      {
        imagenes.length > 1 && (
          <div class="producto__miniaturas">
            {imagenes.map((imagen, i) => (
              <button
                type="button"
                class:list={["producto__miniatura", i === 0 && "producto__miniatura--activa"]}
                data-galeria-miniatura
                data-index={i}
                aria-label={`Ver foto ${i + 1} de ${nombre}`}
              >
                <Image src={imagen} alt="" width={140} height={140} loading="lazy" />
              </button>
            ))}
          </div>
        )
      }
    </div>

    <div class="producto__info">
      <div class="producto__cabecera">
        <span class:list={["insignia", disponible ? "insignia--disponible" : "insignia--pedido"]}>
          {disponible ? "Disponible" : "Sobre pedido"}
        </span>
        <h1>{nombre}</h1>
        <p class="producto__categoria">{categoria}</p>
      </div>

      <div class="producto__descripcion">
        <Content />
      </div>

      <div class="producto__tags">
        {
          tags.map((tag) => (
            <a href={`/catalogo/?tag=${encodeURIComponent(tag.replace(/^#/, ""))}`} class="producto__tag">
              {tag}
            </a>
          ))
        }
      </div>

      <div class="producto__acciones">
        <a href={whatsappOrderLink(nombre)} class="boton boton--whatsapp" target="_blank" rel="noopener">
          Pedir por WhatsApp
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const galeria = document.querySelector<HTMLElement>("[data-galeria]");

  if (galeria) {
    const principales = galeria.querySelectorAll<HTMLImageElement>("[data-galeria-principal]");
    const miniaturas = galeria.querySelectorAll<HTMLButtonElement>("[data-galeria-miniatura]");

    miniaturas.forEach((boton) => {
      boton.addEventListener("click", () => {
        const index = boton.dataset.index;

        principales.forEach((img) => {
          img.hidden = img.dataset.index !== index;
        });

        miniaturas.forEach((b) => {
          b.classList.toggle("producto__miniatura--activa", b === boton);
        });
      });
    });
  }
</script>

<style>
  .producto {
    padding: 2.5rem 0 4rem;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2.5rem;
  }

  @media (max-width: 760px) {
    .producto {
      grid-template-columns: 1fr;
    }
  }

  .producto__galeria {
    display: grid;
    align-content: start;
    gap: 0.85rem;
    background: #fff;
    border-radius: var(--radio);
    box-shadow: var(--sombra);
    padding: 1rem;
  }

  .producto__imagen-principal img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: calc(var(--radio) - 4px);
  }

  .producto__miniaturas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .producto__miniatura {
    padding: 0;
    border: 2px solid transparent;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    background: none;
    line-height: 0;
    width: 100px;
    height: 100px;
    flex-shrink: 0;
  }

  .producto__miniatura img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .producto__miniatura:hover {
    border-color: var(--color-dorado-brillante);
  }

  .producto__miniatura--activa {
    border-color: var(--color-amarillo-oro);
  }

  .producto__info {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: var(--radio);
    box-shadow: var(--sombra);
    padding: 2rem;
  }

  .producto__cabecera {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(96, 73, 50, 0.12);
  }

  .producto__cabecera h1 {
    margin-top: 0.5rem;
  }

  .producto__categoria {
    color: var(--color-gris-morado);
    font-weight: 700;
    margin: 0;
  }

  .producto__descripcion {
    margin: 0 0 1.25rem;
  }

  .producto__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .producto__acciones {
    display: flex;
    justify-content: flex-end;
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(96, 73, 50, 0.12);
  }

  @media (max-width: 480px) {
    .producto__acciones {
      justify-content: stretch;
    }

    .producto__acciones .boton {
      width: 100%;
      justify-content: center;
    }
  }

  .producto__tag {
    font-size: 0.8rem;
    text-decoration: none;
    background: var(--color-crema);
    color: var(--color-oro-quemado);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .producto__tag:hover {
    background: var(--color-amarillo-oro);
    color: var(--color-marron-oscuro);
  }
</style>
