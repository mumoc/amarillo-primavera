---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { whatsappOrderLink } from "../../config/site";

export async function getStaticPaths() {
  const productos = await getCollection("products");
  return productos.map((producto) => ({
    params: { id: producto.id },
    props: { producto },
  }));
}

const { producto } = Astro.props;
const { nombre, categoria, tags, disponible, imagenes } = producto.data;
const { Content } = await render(producto);
---

<BaseLayout title={nombre} description={`${nombre} — ${categoria}, una creación artesanal de Amarillo Primavera.`}>
  <main class="container producto">
    <div class="producto__galeria" data-galeria>
      <div class="producto__imagen-principal">
        {
          imagenes.map((imagen, i) => (
            <Image
              src={imagen}
              alt={`${nombre} — foto ${i + 1}`}
              width={640}
              height={640}
              loading={i === 0 ? "eager" : "lazy"}
              data-galeria-principal
              data-index={i}
              hidden={i !== 0}
            />
          ))
        }
      </div>

      {
        imagenes.length > 1 && (
          <div class="producto__miniaturas">
            {imagenes.map((imagen, i) => (
              <button
                type="button"
                class:list={["producto__miniatura", i === 0 && "producto__miniatura--activa"]}
                data-galeria-miniatura
                data-index={i}
                aria-label={`Ver foto ${i + 1} de ${nombre}`}
              >
                <Image src={imagen} alt="" width={96} height={96} loading="lazy" />
              </button>
            ))}
          </div>
        )
      }
    </div>

    <div class="producto__info">
      <span class:list={["insignia", disponible ? "insignia--disponible" : "insignia--pedido"]}>
        {disponible ? "Disponible" : "Sobre pedido"}
      </span>
      <h1>{nombre}</h1>
      <p class="producto__categoria">{categoria}</p>

      <div class="producto__descripcion">
        <Content />
      </div>

      <div class="producto__tags">
        {
          tags.map((tag) => (
            <a href={`/catalogo/?tag=${encodeURIComponent(tag.replace(/^#/, ""))}`} class="producto__tag">
              {tag}
            </a>
          ))
        }
      </div>

      <a href={whatsappOrderLink(nombre)} class="boton boton--whatsapp" target="_blank" rel="noopener">
        Pedir por WhatsApp
      </a>
    </div>
  </main>
</BaseLayout>

<script>
  const galeria = document.querySelector<HTMLElement>("[data-galeria]");

  if (galeria) {
    const principales = galeria.querySelectorAll<HTMLImageElement>("[data-galeria-principal]");
    const miniaturas = galeria.querySelectorAll<HTMLButtonElement>("[data-galeria-miniatura]");

    miniaturas.forEach((boton) => {
      boton.addEventListener("click", () => {
        const index = boton.dataset.index;

        principales.forEach((img) => {
          img.hidden = img.dataset.index !== index;
        });

        miniaturas.forEach((b) => {
          b.classList.toggle("producto__miniatura--activa", b === boton);
        });
      });
    });
  }
</script>

<style>
  .producto {
    padding: 2.5rem 0 4rem;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2.5rem;
  }

  @media (max-width: 760px) {
    .producto {
      grid-template-columns: 1fr;
    }
  }

  .producto__galeria {
    display: grid;
    gap: 0.75rem;
  }

  .producto__imagen-principal img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radio);
  }

  .producto__miniaturas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .producto__miniatura {
    padding: 0;
    border: 2px solid transparent;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    background: none;
    line-height: 0;
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }

  .producto__miniatura img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .producto__miniatura:hover {
    border-color: var(--color-dorado-brillante);
  }

  .producto__miniatura--activa {
    border-color: var(--color-amarillo-oro);
  }

  .producto__categoria {
    color: var(--color-gris-morado);
    font-weight: 700;
  }

  .producto__descripcion {
    margin: 1rem 0 1.25rem;
  }

  .producto__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.75rem;
  }

  .producto__tag {
    font-size: 0.8rem;
    text-decoration: none;
    background: var(--color-crema);
    color: var(--color-oro-quemado);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .producto__tag:hover {
    background: var(--color-amarillo-oro);
    color: var(--color-marron-oscuro);
  }
</style>
