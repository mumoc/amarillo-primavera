---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_NAME } from "../config/site";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Catálogo de productos artesanales de Amarillo Primavera, hechos a mano en Colima, México.",
  image = "/og-image.png",
  noindex = false,
} = Astro.props;

const tituloCompleto = title === SITE_NAME ? SITE_NAME : `${title} | ${SITE_NAME}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imagenAbsoluta = new URL(image, Astro.site);

const organizacionJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE_NAME,
  url: Astro.site?.toString(),
  logo: new URL("/favicon-512.png", Astro.site).toString(),
  description: "Marca artesanal mexicana, hecha a mano en Colima. Muñecas de trapo, jabones, coronas florales y más.",
  areaServed: "MX",
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#e6a92e" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imagenAbsoluta} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_MX" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tituloCompleto} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imagenAbsoluta} />

    <script type="application/ld+json" set:html={JSON.stringify(organizacionJsonLd)} />

    <title>{tituloCompleto}</title>
  </head>
  <body>
    <Header />
    <div class="page-content">
      <slot />
    </div>
    <Footer />
  </body>
</html>
