---
import { Image } from "astro:assets";

interface Props {
  historia: {
    titulo: string;
    bloques: Array<
      | { tipo: "quote"; texto: string }
      | { tipo: "imagen"; src: ImageMetadata; alt?: string }
      | { tipo: "texto"; parrafos: string[] }
      | {
          tipo: "timeline";
          etapas: Array<{
            titulo: string;
            texto?: string;
            imagenes: ImageMetadata[];
          }>;
        }
      | { tipo: "testimonio"; texto: string; autor?: string }
      | { tipo: "galeria"; imagenes: ImageMetadata[] }
    >;
  };
}

const { historia } = Astro.props;

function numero(i: number): string {
  return String(i + 1).padStart(2, "0");
}
---

<section class="historia">
  <div class="container historia__contenedor">
    <header class="historia__cabecera">
      <span class="historia__kicker">Del taller de Amarillo Primavera</span>
      <h2 class="historia__titulo">{historia.titulo}</h2>
    </header>

    {
      historia.bloques.map((bloque, i) => {
        if (bloque.tipo === "quote") {
          return (
            <blockquote class="historia__quote">
              <p>{bloque.texto}</p>
            </blockquote>
          );
        }

        if (bloque.tipo === "imagen") {
          return (
            <figure class="historia__imagen">
              <Image src={bloque.src} alt={bloque.alt ?? ""} width={1000} height={700} />
            </figure>
          );
        }

        if (bloque.tipo === "texto") {
          return (
            <div class="historia__texto">
              {bloque.parrafos.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          );
        }

        if (bloque.tipo === "timeline") {
          return (
            <ol class="historia__timeline">
              {bloque.etapas.map((etapa, j) => (
                <li class="etapa">
                  <span class="etapa__numero">{numero(j)}</span>
                  <h3 class="etapa__titulo">{etapa.titulo}</h3>
                  {etapa.texto && <p class="etapa__texto">{etapa.texto}</p>}
                  {etapa.imagenes.length === 1 && (
                    <div class="etapa__imagenes etapa__imagenes--una">
                      <Image src={etapa.imagenes[0]} alt="" width={800} height={600} />
                    </div>
                  )}
                  {etapa.imagenes.length === 2 && (
                    <div class="etapa__imagenes etapa__imagenes--dos">
                      {etapa.imagenes.map((img) => (
                        <Image src={img} alt="" width={500} height={500} />
                      ))}
                    </div>
                  )}
                  {etapa.imagenes.length > 2 && (
                    <div class="etapa__imagenes etapa__imagenes--tira">
                      {etapa.imagenes.map((img) => (
                        <Image src={img} alt="" width={420} height={420} />
                      ))}
                    </div>
                  )}
                </li>
              ))}
            </ol>
          );
        }

        if (bloque.tipo === "testimonio") {
          return (
            <figure class="historia__testimonio">
              <blockquote>
                <p>"{bloque.texto}"</p>
              </blockquote>
              {bloque.autor && <figcaption>— {bloque.autor}</figcaption>}
            </figure>
          );
        }

        if (bloque.tipo === "galeria") {
          return (
            <div class="historia__galeria">
              {bloque.imagenes.map((img) => (
                <Image src={img} alt="" width={480} height={480} />
              ))}
            </div>
          );
        }

        return null;
      })
    }
  </div>
</section>

<style>
  .historia {
    padding: 5rem 0 6rem;
    background: var(--color-crema-clara);
    border-top: 1px solid rgba(96, 73, 50, 0.1);
  }

  .historia__contenedor {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    min-width: 0;
  }

  /* Cabecera */
  .historia__cabecera {
    max-width: 680px;
    margin-inline: auto;
    text-align: center;
  }

  .historia__kicker {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-oro-quemado);
    margin-bottom: 0.75rem;
  }

  .historia__titulo {
    margin: 0;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  /* Quote destacado */
  .historia__quote {
    max-width: 780px;
    margin: 1rem auto;
    padding: 0;
    text-align: center;
  }

  .historia__quote p {
    font-family: var(--font-titulos);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    line-height: 1.45;
    color: var(--color-marron-oscuro);
    margin: 0;
  }

  /* Imagen hero */
  .historia__imagen {
    max-width: 920px;
    margin: 0 auto;
  }

  .historia__imagen img {
    width: 100%;
    height: auto;
    border-radius: var(--radio);
    box-shadow: var(--sombra);
  }

  /* Texto (párrafos) */
  .historia__texto {
    max-width: 640px;
    margin-inline: auto;
  }

  .historia__texto p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-marron-oscuro);
  }

  .historia__texto p:last-child {
    margin-bottom: 0;
  }

  /* Timeline */
  .historia__timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 880px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    min-width: 0;
  }

  .etapa {
    max-width: 680px;
    margin-inline: auto;
    text-align: center;
  }

  .etapa__numero {
    display: block;
    font-family: var(--font-titulos);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-amarillo-oro);
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .etapa__titulo {
    margin: 0 0 0.65rem;
    font-size: 1.4rem;
  }

  .etapa__texto {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-marron-oscuro);
    margin: 0 0 1.5rem;
  }

  .etapa__imagenes {
    max-width: 880px;
    margin-inline: auto;
  }

  .etapa__imagenes img {
    border-radius: var(--radio);
    box-shadow: var(--sombra);
    object-fit: cover;
    min-width: 0;
  }

  .etapa__imagenes--una {
    max-width: 560px;
    margin-inline: auto;
  }

  .etapa__imagenes--una img {
    width: 100%;
    height: auto;
  }

  .etapa__imagenes--dos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    min-width: 0;
  }

  .etapa__imagenes--dos img {
    width: 100%;
    aspect-ratio: 1 / 1;
  }

  .etapa__imagenes--tira {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scroll-snap-type: x proximity;
  }

  .etapa__imagenes--tira img {
    flex: 0 0 auto;
    width: 240px;
    aspect-ratio: 1 / 1;
    scroll-snap-align: start;
  }

  @media (max-width: 600px) {
    .etapa__imagenes--dos {
      grid-template-columns: 1fr;
    }
  }

  /* Testimonio editorial */
  .historia__testimonio {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    background: var(--color-crema);
    border-radius: var(--radio);
    padding: 2.5rem 2rem;
  }

  .historia__testimonio blockquote {
    margin: 0;
  }

  .historia__testimonio p {
    font-family: var(--font-titulos);
    font-style: italic;
    font-size: 1.3rem;
    line-height: 1.5;
    color: var(--color-marron-oscuro);
    margin: 0 0 0.85rem;
  }

  .historia__testimonio figcaption {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-oro-quemado);
  }

  /* Galería final */
  .historia__galeria {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    max-width: 1000px;
    margin-inline: auto;
  }

  .historia__galeria img {
    width: 100%;
    min-width: 0;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radio);
    box-shadow: var(--sombra);
  }

  @media (max-width: 600px) {
    .historia__galeria {
      grid-template-columns: 1fr;
    }
  }
</style>
